{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OHDSI/circe-schema/spec/criteria/specimen.schema.json",
  "title": "CIRCE Specimen Criteria Schema",
  "description": "Specimen domain criteria type for CIRCE cohort expressions. Defines Specimen for filtering on biological specimen records in the OMOP CDM.",
  "version": "1.0.0",
  "$defs": {
    "Specimen": {
      "allOf": [
        { "$ref": "./base.schema.json#/$defs/Criteria" },
        {
          "properties": {
            "CodesetId": { "anyOf": [{ "type": "integer" }, { "type": "null" }], "default": null },
            "First": { "anyOf": [{ "type": "boolean" }, { "type": "null" }], "default": null },
            "OccurrenceStartDate": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/DateRange" }, { "type": "null" }], "default": null },
            "OccurrenceEndDate": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/DateRange" }, { "type": "null" }], "default": null },
            "SpecimenType": { "anyOf": [{ "items": { "$ref": "../vocabulary.schema.json#/$defs/Concept" }, "type": "array" }, { "type": "null" }], "default": null },
            "SpecimenTypeCS": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/ConceptSetSelection" }, { "type": "null" }], "default": null },
            "SpecimenTypeExclude": { "default": false, "type": "boolean" },
            "SpecimenSourceConcept": { "anyOf": [{ "type": "integer" }, { "type": "null" }], "default": null },
            "Quantity": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/NumericRange" }, { "type": "null" }], "default": null },
            "Unit": { "anyOf": [{ "items": { "$ref": "../vocabulary.schema.json#/$defs/Concept" }, "type": "array" }, { "type": "null" }], "default": null },
            "UnitCS": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/ConceptSetSelection" }, { "type": "null" }], "default": null },
            "AnatomicSite": { "anyOf": [{ "items": { "$ref": "../vocabulary.schema.json#/$defs/Concept" }, "type": "array" }, { "type": "null" }], "default": null },
            "AnatomicSiteCS": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/ConceptSetSelection" }, { "type": "null" }], "default": null },
            "DiseaseStatus": { "anyOf": [{ "items": { "$ref": "../vocabulary.schema.json#/$defs/Concept" }, "type": "array" }, { "type": "null" }], "default": null },
            "DiseaseStatusCS": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/ConceptSetSelection" }, { "type": "null" }], "default": null },
            "SourceId": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/TextFilter" }, { "type": "null" }], "default": null },
            "Age": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/NumericRange" }, { "type": "null" }], "default": null },
            "Gender": { "anyOf": [{ "items": { "$ref": "../vocabulary.schema.json#/$defs/Concept" }, "type": "array" }, { "type": "null" }], "default": null },
            "GenderCS": { "anyOf": [{ "$ref": "../common.schema.json#/$defs/ConceptSetSelection" }, { "type": "null" }], "default": null }
          },
          "type": "object"
        }
      ]
    }
  }
}
